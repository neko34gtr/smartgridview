<Window x:Class="smartgridview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="スマートデータグリッドビュー" Height="500" Width="800"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True"
        Drop="Window_Drop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox x:Name="chkExtractionMode" Content="抽出モード" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="⚙ 設定" Click="SettingsButton_Click" Margin="0,0,5,0" Padding="5,0"/>
                <Button Content="ℹ About" Click="AboutButton_Click" Padding="5,0"/>
            </StackPanel>
            <TextBlock Text="データを貼り付け(Ctrl+V)またはD&amp;D。" 
                       Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </DockPanel>

        <DataGrid x:Name="dataGrid1" 
                  Grid.Row="1"
                  AutoGenerateColumns="True" 
                  HeadersVisibility="All"
                  RowHeaderWidth="60"
                  GridLinesVisibility="All"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  SelectionUnit="Cell"
                  MouseDoubleClick="dataGrid1_MouseDoubleClick">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                </Style>
            </DataGrid.CellStyle>
        </DataGrid>
    </Grid>
</Window>