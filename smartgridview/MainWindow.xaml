<Window x:Class="smartgridview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartGridView" Height="500" Width="800"
        PreviewKeyDown="Window_PreviewKeyDown"
        AllowDrop="True" Drop="Window_Drop"
        Background="#F9F9F9">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F4F4F4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <CheckBox x:Name="chkSpreadsheetCompatible" Content="スプレッドシート互換" VerticalAlignment="Center" Margin="0,0,15,0"
                          ToolTip="チェック時: ヘッダーが空の列も有効"/>
                <CheckBox x:Name="chkExtractionMode" Content="抽出モード" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Button Content="⚙ 設定" Click="SettingsButton_Click" Margin="0,0,10,0"/>
                <Button Content="ℹ About" Click="AboutButton_Click"/>
            </StackPanel>
            <TextBlock Text="データを貼り付け (Ctrl+V) または ドロップ" 
                       Foreground="#757575" VerticalAlignment="Center" FontSize="13"/>
        </DockPanel>

        <DataGrid x:Name="dataGrid1" Grid.Row="1"
                  AutoGenerateColumns="True" HeadersVisibility="Column"
                  GridLinesVisibility="All" 
                  VerticalGridLinesBrush="#D0D0D0"
                  HorizontalGridLinesBrush="#E0E0E0"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="dataGrid1_MouseDoubleClick"
                  MouseRightButtonUp="dataGrid1_MouseRightButtonUp">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>
    </Grid>
</Window>