<Window x:Class="smartgridview.VerticalViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="詳細表示" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F9F9F9">
    <DockPanel Margin="15">
        <Button DockPanel.Dock="Bottom" Content="閉じる" Click="CloseButton_Click" 
                Padding="20,5" HorizontalAlignment="Right" Margin="0,10,0,0"/>
        <ScrollViewer>
            <StackPanel x:Name="ContainerStackPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>