<Window x:Class="smartgridview.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="450" Width="400" 
        WindowStartupLocation="CenterOwner" Background="#F9F9F9">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="抽出対象キーワードと置換名を設定" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>

        <DataGrid x:Name="mappingGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="True"
                  Background="White" BorderThickness="0" RowHeight="30" Margin="0,0,0,15"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="元のキーワード" Binding="{Binding Target}" Width="*"/>
                <DataGridTextColumn Header="置換後の名前" Binding="{Binding Replacement}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="保存" Click="SaveButton_Click" IsDefault="True" Background="#D0D0D0"/>
        </StackPanel>
    </Grid>
</Window>