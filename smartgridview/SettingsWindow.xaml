<Window x:Class="smartgridview.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="抽出キーワード設定" Height="350" Width="300" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="抽出対象キーワード (1行1項目):" Margin="0,0,0,5"/>
        <TextBox x:Name="keywordsTextBox" Grid.Row="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="キャンセル" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="保存" Width="80" Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>